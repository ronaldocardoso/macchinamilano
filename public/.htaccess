DirectoryIndex index.html

RewriteEngine On

# Keep one canonical, encrypted public URL.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.macchinamilano\.com$ [NC]
RewriteRule ^ https://macchinamilano.com%{REQUEST_URI} [R=301,L]

# Serve exported Next.js directories without exposing index.html.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>
