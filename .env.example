# Phase 0 — active application settings
NODE_ENV="development"
APP_NAME="Macchina Milano"
APP_URL="https://macchinamilano.com"
APP_LOCALE="it-IT"
APP_TIMEZONE="Europe/Rome"
APP_VERSION="0.1.0"
LOG_LEVEL="info"

# Phase 2+ — documented now, activated and validated when implemented
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
AUTH_SECRET=""
AUTH_URL="https://macchinamilano.com"

# Phase 5+ — internal ingestion and scheduled processing
INTERNAL_API_TOKEN=""
WEBHOOK_SIGNING_SECRET=""
CRON_SECRET=""
MIN_VEHICLE_PRICE_EUR=100000
IMPORT_BATCH_SIZE=50
MEDIA_BATCH_SIZE=10
MAX_IMPORT_CONCURRENCY=1
MAX_MEDIA_CONCURRENCY=2
MISSING_THRESHOLD=1
STALE_THRESHOLD=2
INACTIVE_THRESHOLD=3
AUTOSCOUT_ADAPTER_ENABLED=false

# Phase 5+ — media
MEDIA_STORAGE_DRIVER="remote"
MEDIA_LOCAL_PATH=""
MEDIA_PUBLIC_BASE_URL=""

# Phase 6+ — email and leads
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Macchina Milano <noreply@macchinamilano.com>"

# Optional observability
SENTRY_DSN=""
